# Example environment configuration for packwiz-pull-serve

# Required: GitHub webhook secret (should be random & strong, minimum 32 chars)
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-generated-secret-here-minimum-32-characters

# Required: Target GitHub repository (format: github.com/owner/repo)
TARGET_REPO=github.com/your-username/your-modpack-repo

# Required: Branch to watch for changes
TARGET_BRANCH=main

# Required: SSH deploy key (base64-encoded)
# Generate key: ssh-keygen -t ed25519 -f ./deploy-key -N ""
# Base64 encode: cat deploy-key | base64 -w0
# Then export and paste the base64 string below (remove newlines if necessary)
# DEPLOY_KEY=LS0tLS1CRUdJTi... (very long base64 string)
# 
# OR use a mounted key file (comment out DEPLOY_KEY if using this):
# DEPLOY_KEY_PATH=/secrets/deploy-key

# Optional: Local directory where repository will be cloned
# Default: /tmp/packwiz-repo
REPO_PATH=/tmp/packwiz-repo

# Optional: Subdirectory within cloned repo to serve as modpack
# Use "/" to serve from root, or "/modpack", "/pack", etc. for subdirectories
# Default: /
FILE_SERVE_PATH=/

# Optional: Port for webhook listener
# Default: 8080
WEBHOOK_PORT=8080

# Optional: Port for file serving
# Default: 8081
FILE_SERVE_PORT=8081

# Optional: Address to bind to
# Default: 0.0.0.0 (all interfaces)
# LISTEN_ADDR=0.0.0.0
